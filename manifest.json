{
  "manifest_version": 3,
  "name": "LeetBook",
  "version": "1.0",
  "description": "Your personal LeetCode research journal — automatic capture, pattern detection, and AI-powered explanations.",
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "unlimitedStorage",
    "tabs"
  ],
  "host_permissions": [
    "https://leetcode.com/*",
    "http://localhost:11434/*",
    "https://generativelanguage.googleapis.com/*"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://leetcode.com/*"],
      "js": ["src/content.js"]
    }
  ],
  "action": {
    "default_popup": "src/popup/popup.html"
  },
  "web_accessible_resources": [
    {
      "resources": ["src/debug.html", "src/debug.js", "icons/*.png"],
      "matches": ["<all_urls>"]
    }
  ]
}
